# ===========================================
# Zeabur 部署時請在「Web 服務 → Variables」設定
# 不要將真實密碼提交到 Git
# ===========================================

# 必填：資料庫連線（Zeabur Postgres 建立後，從該服務 Variables 複製 POSTGRES_CONNECTION_STRING）
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# 選填：要讓網站跑在 https://你的網域/CLASS_DEMO/ 時設定
# BASE_PATH=/CLASS_DEMO

# 選填：正式環境（Zeabur 通常會自動設）
# NODE_ENV=production
